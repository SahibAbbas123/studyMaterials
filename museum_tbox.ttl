<http://bike-csecu.com/datasets/culturalHeritage/tbox/> rdf:type owl:Ontology;
                                        dc:title "Museum_Onto"@en;
                                        dc:description "An ontology for structuring museum objects"@en;
                                        owl:versionInfo "V0"@en;
                                        dc:creator "Rudra Pratap Deb Nath" . 
